{
  "name": "langctl",
  "version": "0.2.0",
  "description": "Translation management CLI for developers. Manage i18n translations, export to 6 formats (iOS, Android, Flutter, i18next), import translations, and collaborate with teams. Affordable alternative to Lokalise and Crowdin.",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "langctl": "dist/index.js"
  },
  "scripts": {
    "build": "rm -rf dist && tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
